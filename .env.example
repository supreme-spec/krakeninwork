# Smart Security Monitor — Environment Variables Example
# Copy to .env and adjust values

# Node.js server port
PORT=3000

# Сетевой интерфейс для привязки сервера.
# 0.0.0.0 — доступно в локальной сети (камеры/операторы). 127.0.0.1 — только локально.
HOST=0.0.0.0

# API-ключ аутентификации. Если задан — сервер требует его на ВСЕХ /api и /ws.
# Оставьте пустым для открытого локального режима (dev). Перед публикацией обязательно задайте!
# ВАЖНО: API_KEY (сервер) и VITE_API_KEY (клиент) должны совпадать.
API_KEY=
VITE_API_KEY=

# Python Face Engine URL
FACE_SERVER_URL=http://localhost:8001

# API ключ для защиты /update-index на Python-сервере.
# Должен совпадать с FACE_API_KEY в окружении Python.
FACE_API_KEY=super-secret-change-me

# Путь к SQLite (для прямого чтения при старте, с WAL-режимом).
DB_PATH=prisma/dev.db

# Node environment: development | production
NODE_ENV=development

# ── AI Face Engine (Python / FastAPI) ─────────────────────────────────────────
FACE_SERVER_URL=http://localhost:8001
FACE_API_KEY=super-secret-change-me

# Порог распознавания лиц (проценты, 0-100).
# Для buffalo_l рекомендуется >= 55, чтобы избежать ложных срабатываний.
FACE_RECOGNITION_THRESHOLD=55

# Пропуск кадров для снижения нагрузки на инференс (1 = каждый кадр).
FACE_FRAME_SKIP=2

# Минимальный размер лица для распознавания (px).
FACE_MIN_FACE_SIZE=60

# Минимальный порог детекции InsightFace (0.0-1.0).
FACE_MIN_DET_SCORE=0.8

# ── Ворота качества при ЗАПИСИ референсного эмбеддинга (enrollment) ────────────
# Мусорные кадры (размытие/наклон/темнота/несколько лиц) отклоняются ДО попадания
# в БД. Живое распознавание использует мягкие пороги выше (FACE_MIN_DET_SCORE и т.п.).

# Нормированная резкость (0..1, вариация Лапласиана). Ниже — размытие в движении.
FACE_ENROLL_SHARPNESS_MIN=0.35

# Допустимый угол поворота головы (градусы) по pitch/yaw.
FACE_ENROLL_PITCH_MAX=35.0
FACE_ENROLL_YAW_MAX=35.0

# Средняя яркость лица (grayscale 0..255). Ниже — недостаточная освещённость.
FACE_ENROLL_BRIGHTNESS_MIN=40.0

# Максимум лиц в кадре при записи (несколько лиц = неоднозначность).
FACE_ENROLL_MAX_FACES=1

# Калибровочный коэффициент «средняя яркость -> примерный люкс» (для UI).
FACE_BRIGHTNESS_TO_LUX=0.8

# Кулдаун повторного срабатывания для одной персоны (секунды).
FACE_COOLDOWN_SECONDS=30

# Путь к SQLite (для авто-загрузки FAISS при старте, с WAL-режимом).
DB_PATH=prisma/dev.db
# Если уже создана БД без WAL, выполните в SQLite: PRAGMA journal_mode=WAL;
DATABASE_URL="file:./dev.db?journal_mode=WAL"

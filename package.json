{
  "name": "smart-security-monitor",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "predev": "tsx kill-ports.js",
    "dev": "concurrently \"npm:dev:face\" \"npm:dev:server\" \"npm:dev:vite\"",
    "dev:server": "tsx server.ts",
    "dev:face": ".\\venv\\Scripts\\python.exe face_server.py",
    "dev:vite": "vite",
    "build": "vite build && esbuild server.ts --bundle --platform=node --format=esm --packages=external --sourcemap --outfile=dist/server.mjs",
    "start": "NODE_ENV=production node dist/server.mjs",
    "clean": "Remove-Item -Recurse -Force dist -ErrorAction SilentlyContinue",
    "lint": "tsc --noEmit --skipLibCheck",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate deploy",
    "db:studio": "prisma studio",
    "postinstall": "prisma generate"
  },
  "dependencies": {
    "@prisma/client": "^5.22.0",
    "@tailwindcss/vite": "^4.1.14",
    "@types/archiver": "^8.0.0",
    "@types/node-fetch": "^2.6.12",
    "@types/unzipper": "^0.10.11",
    "@vitejs/plugin-react": "^5.0.4",
    "archiver": "^8.0.0",
    "concurrently": "^9.1.0",
    "dotenv": "^17.2.3",
    "express": "^4.21.2",
    "lucide-react": "^0.546.0",
    "motion": "^12.23.24",
    "multer": "^2.2.0",
    "node-fetch": "^3.3.2",
    "react": "^19.0.1",
    "react-dom": "^19.0.1",
    "react-router-dom": "^7.18.1",
    "sharp": "^0.35.3",
    "unzipper": "^0.12.5",
    "vite": "^6.2.3",
    "ws": "^8.21.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/multer": "^2.2.0",
    "@types/node": "^22.14.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@types/sharp": "^0.31.1",
    "@types/ws": "^8.18.1",
    "autoprefixer": "^10.4.21",
    "esbuild": "^0.25.0",
    "prisma": "^5.22.0",
    "tailwindcss": "^4.1.14",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2",
    "vite": "^6.2.3"
  }
}
